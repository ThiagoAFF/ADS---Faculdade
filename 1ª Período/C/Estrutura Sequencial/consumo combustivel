#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {

  float distancia, combustivel, consumo;
  printf("Digite a distancia percorrida em Km: ");
  scanf("%f", &distancia);
  clear();
  printf("Digite o combustivel gasto em Litros: ");
  scanf("%f", &combustivel);
  consumo = distancia / combustivel;
  clear();
  printf("O consumo medio do veiculo e: %.2f\n", consumo);
  return 0;
}
