#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {

    int num1, num2, num3;
 
    printf("Digite o primeiro número: ");
    scanf("%d", &num1);
    clear();
    printf("Digite o segundo número: ");
    scanf("%d", &num2);
    clear();
    printf("Digite o terceiro número: ");
    scanf("%d", &num3);
    clear();
    if (num1 > num2 && num1 > num3)
        printf("%d é maior que %d e %d", num1, num2, num3);
    if (num1 == num2 && num1 == num3)
        printf("Todos números são iguais");
    if (num2 > num1 && num2 > num3)
        printf("%d é maior que %d e %d", num2, num1, num3);
    if (num3 > num1 && num3 > num2)
        printf("%d é maior que %d e %d", num3, num1, num2);
 
    return 0;

}
