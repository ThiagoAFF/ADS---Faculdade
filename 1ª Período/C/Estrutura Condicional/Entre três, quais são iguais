#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {
 int num1, num2, num3;

    printf("Digite o primeiro número: ");
    scanf("%d", &num1);
    printf("Digite o segundo número: ");
    scanf("%d", &num2);
    printf("Digite o terceiro número: ");
    scanf("%d", &num3);
    clear();

    if (num1 == num2 && num2 == num3)
        printf("Os três números são iguais.");
    if (num1 == num2 && num2 != num3)
        printf("%d e %d são iguais.", num1, num2);
    if (num1 == num3 && num2 != num3)
        printf("%d e %d são iguais.", num1, num3);
    if (num2 == num3 && num1 != num2)
        printf("%d e %d são iguais.", num2, num3);
    if (num1 != num2 && num2 != num3 && num1 != num3)
        printf("Os três números são diferentes.");
return 0;
}
