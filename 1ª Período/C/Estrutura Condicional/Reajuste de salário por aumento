#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {

    float sal;

    printf("Digite o salário: ");
    scanf("%f", &sal);
    clear();
    if (sal < 1000){
        sal = sal + (sal * 0.10);
        printf("Reajuste com o aumento de 10%: %.2f", sal);
    }

    else{
        sal = sal + (sal * 0.05);
        printf("Reajuste com o aumento de 5%: %.2f", sal);
    }

return 0;
}
