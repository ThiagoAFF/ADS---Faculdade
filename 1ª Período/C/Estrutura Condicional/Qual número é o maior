#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {

    int num1, num2;

    printf("Digite o primeiro número: ");
    scanf("%d", &num1);
    clear();
    printf("Digite o segundo número: ");
    scanf("%d", &num2);
    clear();

    if (num1 > num2)
        printf("%d é maior que %d", num1, num2);
    if (num1 == num2)
        printf("%d é igual a %d", num1, num2);
    else
        printf("%d é maior que %d", num2, num1);
 
    return 0;
 
}
