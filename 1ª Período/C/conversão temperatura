#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {
//F = (C * 9/5) + 32
    float celsius, fahrenheit;
    printf("Digite a temperatura em Celsius: ");
    scanf("%f", &celsius);
    fahrenheit = (celsius * 9/5) + 32;
    printf("A temperatura em Fahrenheit é: %.2f\n", fahrenheit);
}
