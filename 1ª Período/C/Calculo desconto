#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {

    float valorproduto, desconto, valorfinal;
    printf("Digite o valor do produto: ");
    scanf("%f", &valorproduto);
    clear();
    printf("Digite o valor do desconto: ");
    scanf("%f", &desconto);
    clear();
    valorfinal = valorproduto - (valorproduto * desconto / 100);
    printf("O valor final do produto é: %.2f\n", valorfinal);
}
