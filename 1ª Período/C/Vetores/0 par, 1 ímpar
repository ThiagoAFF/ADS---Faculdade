#include <stdio.h>
#include <stdbool.h>
void clear() { printf("\033[2J\033[H"); }

int main() {
  int p; // p = Parágrafo
  float v[10]; // v = Vetor

  for (p = 1; p <= 10; p++){
    if((p % 2) == 0){
      v[p] = 0;
    }
    else{
       v[p] = 1;
    }
    printf("%.0f\n", v[p]);
  }

  return 0;
}
