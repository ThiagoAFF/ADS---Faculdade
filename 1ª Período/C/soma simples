#include <stdio.h>

void clear() { printf("\033[2J\033[H"); }

int main() {
    int valor1, valor2, soma;
    printf("Digite o primeiro valor: ");
    scanf("%d", &valor1);
    clear();
    printf("Digite o segundo valor: ");
    scanf("%d", &valor2);
    soma = valor1 + valor2;
    clear();
    printf("A soma dos valores é: %d\n", soma);

}
