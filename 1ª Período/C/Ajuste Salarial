#include <stdio.h>

void clear() {
    printf("\033[2J\033[H");
}

int main()
{

    float salI, salF, ajs;

    printf("Digite seu salário atual: ");
    scanf("%f", &salI);
    clear();
    printf("Digite o ajuste percentual: ");
    scanf("%f", &ajs);
    clear();

    salF = salI * (1+(ajs/100));

    printf("O novo salário é: %.2f", salF);
    return 0;
}



