#include <stdio.h>
void clear() { printf("\033[2J\033[H"); }

int main() {
  int num = 1, exc, numSum = 0;

  for(num = 1; num <= 50; num++){
    printf("Digite um número: ");
    scanf("%d", &exc);
    if((exc % 2) != 0){
      numSum = numSum + exc;
    };

    clear();
  }

  printf("A soma dos números ímpares é: %d", numSum);

  return 0;
}
