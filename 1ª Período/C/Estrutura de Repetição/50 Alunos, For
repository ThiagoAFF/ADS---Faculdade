#include <stdio.h>
void clear() { printf("\033[2J\033[H"); }

int main() {
  int notaA, aluno = 1;
  float notaP = 0;

  for(aluno = 1; aluno <= 5; aluno ++) {
    printf("Digite a nota do aluno %d: ", aluno);
    scanf("%d", &notaA);

    notaP = notaP + notaA;

  };

  notaP = notaP / (aluno - 1);

  printf("A média da turma é: %.1f", notaP);

  return 0;
}
